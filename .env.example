# Google Cloud & Authentication
GOOGLE_TOKEN_PATH=token.pickle
GOOGLE_PROJECT_ID=your-gcp-project-id

# Telegram Bot (Phase 4+)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_OWNER_CHAT_ID=your_chat_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-haiku-4-5-20251001  # Claude model to use for draft generation

# Application Settings
BAD_REVIEW_THRESHOLD=3                    # Notify on reviews with this rating or lower
POLL_INTERVAL_MINUTES=5                   # Check for new reviews every N minutes
PORT=8080                                 # Web server port
DRY_RUN=false                             # Set true to skip actually posting to Google
LOG_LEVEL=INFO                            # DEBUG for local dev, INFO for production
